<!-- <?xml version="1.0" encoding="UTF-8" ?>
<!-- Delphi SIL component configuration -->
<DATA_Extracter_Configuration>
	<!--DATA_Extracter_Config_XML_Version -->
	<!-- Version X.Y where:
		X - major change where some new parameters were added
		Y - minor change with no influence on parsing (comment or value change) -->
	<DATA_Extracter_Config_XML_Version>2.4</DATA_Extracter_Config_XML_Version>
	
	<!-- Resim output path selection. Options are SAME_AS_INPUT or NEW_OUTPUT_PATH or SAME_AS_OUTPUT
           SAME_AS_OUTPUT : This is Optional . Files will generated path provided in the third command line argument	-->
         <Output_Path_Options>SAME_AS_OUTPUT</Output_Path_Options>
    <!-- If resim output path selection is NEW_OUTPUT_PATH use the below tag to enter valid folder path -->
		 <Output_Path_Location>NONE</Output_Path_Location>


    <!-- Data_Extraction_Mode User Options : 
				
	Log_Quality_Check :
	            0 : Does not prints  prints Packet loss Info 
                1 :  prints Packet loss  Summary Table at the end 	-->	
		
        <Data_Extraction_Mode> 		
               				<Log_Quality_Summary>1</Log_Quality_Summary> 
		</Data_Extraction_Mode>

		
</DATA_Extracter_Configuration>
