<?xml version="1.0" encoding="UTF-8" ?>
<!-- SRR3 Delphi SIL component configuration -->

<Embedded_Library_Output_Control>
	<!-- SIL SRR3 Embedded_Library Configuration Control XML Version -->
	<!-- Version X.Y where:
		X - major change where some new parameters were added
		Y - minor change with no influence on parsing (comment or value change) -->	
	<SIL_SRR3_Embedded_Library_Output_Control_XML_Version>2.4</SIL_SRR3_Embedded_Library_Output_Control_XML_Version>
		<!-- XML Configuration Control for the Transmission of CAN Data - 
				CAN_TX_ENABLED - Send RESIM outputs to CANoe(in Live mode) 
				CAN_TX_DISABLED-Don't send RESIM outputs to CANoe -->
  <CAN_TRANSMISSION>CAN_TX_DISABLED</CAN_TRANSMISSION>
	
	<!-- XML Configuration Control for the Transmission of UDP Data- 
				UDP_TX_ENABLED - Send RESIM outputs to Orcas(in Live mode) 
				UDP_TX_DISABLED-Don't send RESIM outputs to Orcas -->
  <UDP_TRANSMISSION>UDP_TX_DISABLED</UDP_TRANSMISSION>
				
	<!-- XML Configuration Control for Embedded_Library Output XML Trace Files- 
				XML_TRACE_ENABLED - GENERATE Embedded_Library Output XML Trace Files 
				XML_TRACE_DISABLED - SUPPRESS Embedded_Library Output XML Trace Files -->
  <XML_Trace_Files>XML_TRACE_ENABLED</XML_Trace_Files>

  <!-- XML Configuration Control for Embedded_Library Output XML Trace Files for RNA- 
				CDC_CHECK_ENABLED - GENERATE Embedded_Library Output XML Trace Files 
				CDC_CHECK_DISABLED - SUPPRESS Embedded_Library Output XML Trace Files -->
  <CDC_CHECK_Files>CDC_CHECK_DISABLED</CDC_CHECK_Files>
  
  <!--XML Configuration Control for Embedded_Library plp synchronization 
	             ENABLE_TRACKER_MODE- Synchronize plp timestamp to output 
               DISABLE_TRACKER_MODE- SUPPRESS Synchronize plp timestamp to output -->
  <LOAD_TRACKER_INTERNALS>ENABLE_TRACKER_MODE</LOAD_TRACKER_INTERNALS>
  
 	<!-- External Error via XML Configuration Control for Embedded_Library Output XML Trace Files- 
				EXTERNAL_ERROR_XML_ENABLED - GENERATE Embedded_Library Output XML Trace Files 
				EXTERNAL_ERROR_XML_DISABLED - SUPPRESS Embedded_Library Output XML Trace Files -->
  <LOAD_ANERMA_ERROR>EXTERNAL_ERROR_XML_DISABLED</LOAD_ANERMA_ERROR>
  <!-- XML Configuration Control for Embedded_Library Output XML Trace Files- 
				USC_NORMAL - Loads the USC from the UDP logs
				USC_READ_FROM_XML - Loads the USC from the XML file -->
<USC_XML_Control>USC_NORMAL</USC_XML_Control>

<!--XML Configuration Control for Embedded_Library USC CSV Mode extraction
				ENABLE_USC_CSV_MODE Genearate usc csv to output
				DISABLE_USC_XML_MODE SUPPRESS  usc csv to output -->
<Suppress_Usc_Csv_log>DISABLE_USC_XML_MODE</Suppress_Usc_Csv_log>

<!--XML Configuration Control for Embedded_Library USC XML mode extraction
				ENABLE_USC_XML_MODE Generate usc xml to output
				DISABLE_USC_XML_MODE SUPPRESS usc xml to output -->
<Suppress_Usc_Xml_log>ENABLE_USC_XML_MODE</Suppress_Usc_Xml_log>
	
    <!-- Angular Error Manipulation (ANERMA) - 
     Path for test and reference files which stores the required parameters to simulate angular error noise (for testing and analysis) -->

  <ANERMA_PARAMETER_FILE_REFERENCE>C:/anerma/AU536</ANERMA_PARAMETER_FILE_REFERENCE>
  <ANERMA_PARAMETER_FILE_TEST>C:/anerma/PO513</ANERMA_PARAMETER_FILE_TEST>
  
  <PLP_Resim>
    <plp_algorithems>0</plp_algorithems><!-- 0 => Enable -->
    <plp_analysis>1</plp_analysis><!-- 1 => Enable -->
  </PLP_Resim> 
  
    <!-- Parts of XML Prints: 1 => Generate XML Print 
							  0 => Suppress XML Print -->
	<XML_Prints>
		<Vehicle_Info>1</Vehicle_Info>
		<Mounting_Info>1</Mounting_Info>
		<MNR_blockage>1</MNR_blockage>
		<TD_blockage>1</TD_blockage>
		<Self_Dets>1</Self_Dets>
		<Opp_Dets>1</Opp_Dets>
    <scan_prints>1</scan_prints>
    <Cal_Error_Files>1</Cal_Error_Files>
    <Active_Faults>1</Active_Faults>
    <UDP_Datas>1</UDP_Datas>
		<Curvi_Tracks>1</Curvi_Tracks>
		<Alignment_Info>1</Alignment_Info>
		<Z4_Z7B_Cust_Data>1</Z4_Z7B_Cust_Data>
		<ADC_Physical_Data>1</ADC_Physical_Data>
		<Algo_Z7B_core>1</Algo_Z7B_core> <!-- Algo Timing Info of Z7B core -->
		<Algo_Z7A_core>1</Algo_Z7A_core> <!-- Algo Timing Info of Z7A core -->
		<Algo_Z4_core>1</Algo_Z4_core> <!-- Algo Timing Info of Z4 core -->
		<PATH_Tracking_Info>1</PATH_Tracking_Info>
		<LCDA_Info>1</LCDA_Info> 
		<CTA_Info>1</CTA_Info>
		<RECW_Info>1</RECW_Info>
		<ASW_Info>1</ASW_Info>
		<ABA_Info>1</ABA_Info>
  </XML_Prints>
	
	<!-- XML Configuration Control for Embedded_Library Input and Output CSV Files-   
				1 - GENERATE Embedded_Library input CSV Files for all logging streams
				0 - SUPPRESS Embedded_Library Output CSV Files for all logging streams -->
	<UDP_Log_Data_CSV>0</UDP_Log_Data_CSV>
	
	<!-- XML Configuration Control for Embedded_Library Input and Output CSV Files-   
				1 - GENERATE Embedded_Library PCAN_DECODER_XML  Files 
				0 - SUPPRESS Embedded_Library PCAN_DECODER_XML  Files-->
	<PCAN_DECODER_XML>0</PCAN_DECODER_XML>
	
	<!-- XML Configuration Control for Embedded_Library Input and Output CSV Files-   
				1 - GENERATE Embedded_Library input XML Trace Files for all logging streams
				0 - SUPPRESS Embedded_Library Output XML Trace Files for all logging streams -->
	<UDP_Log_Data_XML_TRACE>0</UDP_Log_Data_XML_TRACE>
	
	<!-- XML Configuration Control for Embedded_Library Output BIN Files-   
				BIN_FILES_ENABLED - GENERATE Embedded_Library Output BIN Files 
				BIN_FILES_DISABLED - SUPPRESS Embedded_Library Output BIN Files -->
  <BIN_FILES>BIN_FILES_ENABLED</BIN_FILES>
	
	<!-- XML Configuration Control for Embedded Library Console Prints-   
				CONSOLE_PRINTS_ENABLED - Enable Console Prints while execution 
				CONSOLE_PRINTS_DISABLED - Disable Console Prints while execution -->
  <CONSOLE_PRINTS>CONSOLE_PRINTS_ENABLED</CONSOLE_PRINTS>
	
	<!-- XML Configuration Control for Embedded_Library DGPS Decoding -
				DGPS_DECODE_ENABLE - Enable DGPS Decoding in EB.. NOTE: NEED TO PROVIDE PROPER GPS MF4 FILE IN JSON BN_IUKETH section 
				DGPS_DECODE_DISABLE - Disable DGPS Decoding in EB -->
	<DGPS_Decode_Status>DGPS_DECODE_DISABLE</DGPS_Decode_Status>
	
	<!-- XML Configuration Control for Embedded_Library SM2 Execution control -
				SM2_ENABLE 	- Enable Sensor Model Execution in EB.. NOTE: Need DGPS ENABLED and NEED TO PROVIDE PROPER GPS MF4 FILE IN JSON BN_IUKETH section 
				SM2_DISABLE - Disable Sensor Model Execution in EB.. -->
	<SM2_Execution_Status>SM2_DISABLE</SM2_Execution_Status>
	
	<!-- Sensor Model and MESH configuration path to be provided here -
				Provide the complete path for the Sensor Model Config and MESH Config accrodingly here
				Without this paths the SM code will not Execute hence this is a Mandatory Field for SM2 in RESIM-->
	<SM2_Config_File>NONE</SM2_Config_File>
	<MESH_Config_File>NONE</MESH_Config_File>
	
	<!-- XML Configuration Control for Enabling / Disabling the Auto Alignment BMW_SRR5- 
				AUTO_ALIGN_ENABLED - INITIALIZE_AUTO_ALIGNMENT_FROM_INTERNALS 
				AUTO_ALIGN_DISABLED - AUTO_ALIGNMENT_USE_VALUE_FROM_UDP  -->
	<Auto_Align_Option>AUTO_ALIGN_ENABLED</Auto_Align_Option>
	
	<!-- Embedded_Library Output BIN Files for all Customers
	    BIN File selection values: 1 => Generate Embedded_Library Output BIN Files for Enabled BIN Files
								   0 => Suppress Embedded_Library Output BIN Files for Disabled BIN Files -->		
    <BIN_Files>	
		<DETECTIONS>0</DETECTIONS>
		<TRACKER_OUT>0</TRACKER_OUT>
		<RADAR_PARAM>0</RADAR_PARAM>
		<VEHICLE_DATA>0</VEHICLE_DATA>
		<GROUPED_TRACKLETS>0</GROUPED_TRACKLETS>
		<DEBUG_DETECTION_GROUPS>0</DEBUG_DETECTION_GROUPS>
		<FEATURES>0</FEATURES>
		<LCDA>0</LCDA>
		<RECW>0</RECW>
		<CTA>0</CTA>
		<ASW>0</ASW>
		<VISOB>0</VISOB>
		<Freespace>0</Freespace>
		<ABA>0</ABA>
		<Timing_Info>0</Timing_Info>
		<TODS>0</TODS>
	</BIN_Files>




</Embedded_Library_Output_Control>

