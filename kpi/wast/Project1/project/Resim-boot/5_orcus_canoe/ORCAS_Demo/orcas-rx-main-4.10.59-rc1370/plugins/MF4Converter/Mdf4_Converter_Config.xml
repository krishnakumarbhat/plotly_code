<?xml version="1.0" encoding="UTF-8" ?>
<!--  APTIV SIL component configuration -->
<CONVERTOR_CONFIGURATION>
  <!-- SIL SRR5 Configuration XML version -->
  <!-- Version X.Y where:
		X - major change where some new parameters were added
		Y - minor change with no influence on parsing (comment or value change) -->
  <CONVERTOR_CONFIGURATION_XML_VERSION>2.6</CONVERTOR_CONFIGURATION_XML_VERSION>

<!-- Input Mode Options available are -
    ORCAS_MDF4_INPUT : Input to the convertor will be ORCAS_MDF4
	CANAPE_MDF4_INPUT: Input to the convertor will be CANAPE_MDF4
	VIGEM_MDF4_INPUT : Input to the convertor will be VIGEM_MDF4
	VIGEM_VPCAP_INPUT: Input to the convertor will be VIGEM_VPCAP_MDF4
	RESIM_VIGEM_MDF4_INPUT: Input to the convertor will be resimulated SOMEIP VIGEM_MDF4	-->
	
	<CONVERTOR_INPUT_FILE_OPTION>
		<ORCAS_MDF4_INPUT>0</ORCAS_MDF4_INPUT>
		<PCAP_INPUT>0</PCAP_INPUT>
		<AUTERA_INPUT>0</AUTERA_INPUT>
		<CANAPE_MDF4_INPUT>0</CANAPE_MDF4_INPUT>
		<CANAPE_CAN_MDF4_INPUT>0</CANAPE_CAN_MDF4_INPUT>
		<VIGEM_MDF4_INPUT>1</VIGEM_MDF4_INPUT>
		<VIGEM_VPCAP_INPUT>0</VIGEM_VPCAP_INPUT>
		<X2E_INPUT>0</X2E_INPUT>
		<RESIM_VIGEM_MDF4_INPUT>0</RESIM_VIGEM_MDF4_INPUT>
		<BRR_INPUT>0</BRR_INPUT>
	</CONVERTOR_INPUT_FILE_OPTION>
	
	<!-- Output Mode Options available are -
	SINGLE_DVSU_OUTPUT : Output will be single_dvsu file
	FOUR_DVSU_OUTPUT   : Output will be Four dvsu files
	ORCAS_MDF4_OUTPUT  : Output will be ORCAS_MDF4_OUTPUT file
	CANoe_MDF4_OUTPUT  : Output will be CANoe or CANAPE MDF4 file
	VIGEM_MDF4_OUTPUT  : Output will be ViGEM MDF4 
	VIGEM_SOMEIP_OUTPUT: Output will be CANOE SOMEIP MDF4
	VIGEM_VPCAP_OUTPUT : Output will be ViGEM VPCAP MDF4 
	VIDEO_OUTPUT       : Output will be video file 
-->	
	<CONVERTOR_OUTPUT_FILE_OPTION>
		<SINGLE_DVSU_OUTPUT>0</SINGLE_DVSU_OUTPUT>
		<FOUR_DVSU_OUTPUT>0</FOUR_DVSU_OUTPUT>
		<ORCAS_MDF4_OUTPUT>0</ORCAS_MDF4_OUTPUT>
		<CANoe_MDF4_OUTPUT>0</CANoe_MDF4_OUTPUT>
		<VIGEM_MDF4_OUTPUT>0</VIGEM_MDF4_OUTPUT>
		<CANAPE_MDF4_OUTPUT>0</CANAPE_MDF4_OUTPUT>
		<CANoe_SOMEIP_OUTPUT>1</CANoe_SOMEIP_OUTPUT>
		<ViGEM_SOMEIP_OUTPUT>0</ViGEM_SOMEIP_OUTPUT>
		<PCAP_OUTPUT>0</PCAP_OUTPUT>
		<VIDEO_OUTPUT>0</VIDEO_OUTPUT>
	</CONVERTOR_OUTPUT_FILE_OPTION>
	
	
	<!-- CONVERT_ONLY_SRR_DEBUG_FILES = 1 : Input is taken from only the SRR_DEBUG folder and converts accordingly
	     CONVERT_ONLY_SRR_DEBUG_FILES = 0 : Input is taken from CALIFR,FASETH,SRR_REFERENCE and the SRR_DEBUG folder and converts accordingly-->
	<CONVERT_ONLY_SRR_DEBUG_FILES>1</CONVERT_ONLY_SRR_DEBUG_FILES>
	
	<!-- HIL_port_xml = 1 : Only HIL port(6001)data will be written to the output ORCAS MF4 file
         Sensor_xml   = 1 : Only Sensor port(5555)data will be written to the output ORCAS MF4 file
		 Dspace_xml   = 1 : Only dspace port(5556)data will be written to the output ORCAS MF4 file-->
	<HIL_port>0</HIL_port> 
	<Sensor_port>1</Sensor_port> 
	<Dspace_port>0</Dspace_port>
				
	<!-- The below tags are applicable only for Vigem to ORCAS and AUTERA to ORCAS conversions and Vigem to canoe conversion-->
	
	<!-- MERGE_CONVERTED_DATA = MERGE_ALL_TRACES_TO_SINGLE_FILE             : Merge All records to single file.
	     MERGE_CONVERTED_DATA = MERGE_RESPECTIVE_STREAMS_TO_INDIVIDUAL_FILE : Merge All Califr to single Califr, All FASETH to single FASETH, ALL SRR_DEBUG to single SRR_DEBUG, All SRR_REF to Single SRR_REF-->
	<MERGE_CONVERTED_DATA>MERGE_RESPECTIVE_STREAMS_TO_INDIVIDUAL_FILE</MERGE_CONVERTED_DATA>
	
	<!--CREATE_SEPERATE_OUTPUTS = 1 : Create seperate orcas files for each input without merging-->
	<CREATE_SEPERATE_OUTPUTS>1</CREATE_SEPERATE_OUTPUTS>
	
	<!-- CSV_ENABLE = 1 : CSV files will be generated along with the converted file output. Csv contains header data info of log
	     CSV_ENABLE = 0 : No CSV files will get generated along with the converted file output-->
	<CSV_ENABLE>0</CSV_ENABLE>
	
	<!--Output Path Options	
	SAME_AS_INPUT                  - Output will be created in the path of SRR_DEBUG file
	OUTPUT_INSIDE_CONVERTED_FOLDER - CONVERTED folder will be created inside SRR DEBUG folder.Applicable only for vigem to orcas conversion.
	C:\test\                       - User Defined Output path.Applicable only for vigem to orcas conversion
	OUTPUT_INSIDE_CONV_FOLDER      - CONV folder will be created next to SRR_DEBUG folder. Option applicable only when remote pc log path is used in json.
	-->
	<CONVERTOR_OUTPUT_PATH>SAME_AS_INPUT</CONVERTOR_OUTPUT_PATH>
	
	<!--IGNORECDC = TRUE    --   The CDC content from VIGEM input wont be written in the Output
	    IGNORECDC = FALSE    --  The CDC content from VIGEM input will be written in the Output-->
	<IGNORECDC>TRUE</IGNORECDC>
	</CONVERTOR_CONFIGURATION>