; Copyright 2022 Vector Informatik GmbH
[Version]
Signature      = "$CHICAGO$"
Class          = Vector-Hardware
ClassGuid      = {D20399E0-47BD-4219-8C5B-A10B87CEB545}
Provider       = %MFGNAME%
DriverVer=10/28/2022,22.20.20.0
CatalogFile.NTamd64=vt6306_64.cat

[Manufacturer]
%MFGNAME%=DeviceList,NTamd64

;------------------------------------------------------------------------------
;  Supported Devices
;------------------------------------------------------------------------------
; Windows 7 and later versions
[DeviceList.NTamd64]
%DESCRIPTION_VT6306%=DI_vt6306, {731CB318-600C-48FB-AB27-C8B8D5045D6C}\PID_029098
%DESCRIPTION_VT6306B%=DI_vt6306, {731CB318-600C-48FB-AB27-C8B8D5045D6C}\PID_029135
;-------------------------------------------------------------------------
; Class Section
;-------------------------------------------------------------------------
[ClassInstall32]
Addreg=CanClassReg

[CanClassReg]
HKR,,,0,%ClassName%
HKR,,Icon,,"-5"

;-------------------------------------------------------------------------
; Device Install Section
;-------------------------------------------------------------------------
[ControlFlags]
ExcludeFromSelect = *

;------------------------------------------------------------------------------
;  Installation Disk Information
;------------------------------------------------------------------------------
[SourceDisksFiles]
vt6306.sys = 1
WdfCoInstaller01009.dll = 1 ; make sure the number matches with SourceDisksNames

[SourceDisksNames]
1=%INSTDISK%,

;------------------------------------------------------------------------------
; DestinationDirs 
;------------------------------------------------------------------------------
[DestinationDirs]
DefaultDestDir=12
CoInstaller_CopyFiles = 11

;------------------------------------------------------------------------------
;  Windows Sections
;------------------------------------------------------------------------------
[DI_vt6306.NTamd64]
CopyFiles      = @vt6306.sys
AddReg=vt6306.registry,options.registry

[DI_vt6306.NTamd64.Services]
AddService     = vt6306,0x00000002,vt6306_Service

[vt6306_Service]
DisplayName    = %SVCDESC_VT6306%
ServiceType    = 1                  ; SERVICE_KERNEL_DRIVER
StartType      = 3                  ; SERVICE_DEMAND_START
ErrorControl   = 1                  ; SERVICE_ERROR_NORMAL
ServiceBinary  = %12%\vt6306.sys


;-------------------------------------------------------------------------
; WDF Coinstaller installation
;-------------------------------------------------------------------------
[DI_vt6306.NTamd64.CoInstallers]
AddReg         = CoInstaller_AddReg
CopyFiles      = CoInstaller_CopyFiles

[CoInstaller_CopyFiles]
WdfCoInstaller01009.dll

[CoInstaller_AddReg]
HKR,,CoInstallers32,0x00010000, "WdfCoInstaller01009.dll,WdfCoInstaller"

[DI_vt6306.NTamd64.Wdf]
KmdfService    = vt6306, vt6306_wdfsect

[vt6306_wdfsect]
KmdfLibraryVersion = 1.9

;------------------------------------------------------------------------------
;  Add Registry Entrys
;------------------------------------------------------------------------------
[vt6306.registry]
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Drivers\VT6306",MaxCards,0x10001,8
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Drivers\VT6306",TimerEligibility,0x10001,0x300
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Drivers\VT6306",ChannelsPerCard,0x10001,8
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Drivers\VT6306",HwType,0x10001,107
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Drivers\VT6306",HwName,,"vt6306"
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Drivers\VT6306",DriverName,,vt6306
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Drivers\VT6306",UseDeviceInterface,0x10001,1

HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Hardware\VT6306",UseCardSerialNumber,0x10003,0
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Hardware\VT6306",RxTransferCycleTime,0x10003,250

;------------------------------------------------------------------------------
;  Add common registry entries
;------------------------------------------------------------------------------
[options.registry]
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Options",OEMInstallation,0x10001,0
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Options",DebugFlags,0x10003,0
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Options",EnableTimeSync,0x10003,1
HKLM,"SOFTWARE\VECTOR\CANDriver 1.0\Options",VirtualBus,0x10003,1

;------------------------------------------------------------------------------
;  String Definitions
;------------------------------------------------------------------------------
[Strings]
;DriverSetupDirectory="VT6306"
MFGNAME               = "Vector Informatik GmbH"
INSTDISK              = "VT6306-Driver"
DESCRIPTION_VT6306    = "VT6306"
DESCRIPTION_VT6306B   = "VT6306B"
ClassName             = "Vector-Hardware"
SVCDESC_VT6306        = "VT6306"
SVCDESC_VT6306B       = "VT6306B"
