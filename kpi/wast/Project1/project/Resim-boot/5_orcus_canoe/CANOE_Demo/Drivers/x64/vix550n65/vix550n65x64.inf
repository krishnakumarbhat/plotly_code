[NO_DRV]
Characteristics    = 0x01
Include            = pci.inf
Needs              = NO_DRV

[NO_DRV.Services]
Include            = pci.inf
Needs              = NO_DRV.Services

; ---------------------------------------------------
; Intel(R) Ethernet Converged Network Adapter X550-T1
; ---------------------------------------------------
[S15D1_SP]
Characteristics    = 0x84 ; NCF_HAS_UI | NCF_PHYSICAL
BusType            = 5 ; PCI
DelReg             = Advanced.DelReg
AddReg             = Default.reg, RSC.reg, QOS.reg, VMQ.reg, Sriov.reg, Triplespeed.reg,  DMACoalescing.reg, Powermgmt.reg, Uninstall.reg
AddReg             = DCB.reg,  IPSec.reg
AddReg             = CoInKPM.reg
CopyFiles          = CopyFiles, MessageDll.CopyFiles, Uninstall.CopyFiles
*IfType            = 6     ; IF_TYPE_ETHERNET_CSMACD
*MediaType         = 0     ; NdisMedium802_3
*PhysicalMediaType = 14    ; NdisPhysicalMedium802_3

[S15D1_SP.Services]
AddService = %ServiceName%, 2, Service, EventLog

[S15D1_SP.HW]
Include            = pci.inf
Needs              = PciSriovSupported.HW, PciIoSpaceNotRequired.HW
AddReg             = MSI.reg

[S15D1_SP.CoInstallers]
AddReg             = CoInstaller_AddReg, CoInKPM.reg
CopyFiles          = CoInstallerCopyFiles

