; Copyright 2022 Vector Informatik GmbH
[Version]
Signature      = "$CHICAGO$"
Class          = Vector-Hardware
ClassGuid      = {D20399E0-47BD-4219-8C5B-A10B87CEB545}
Provider       = %MSFT%
DriverVer=06/03/2022,22.12.16.0
CatalogFile.NTamd64=vnUsbClient8911Win10_64.cat

;------------------------------------------------------------------------------
;  Supported Devices
;------------------------------------------------------------------------------
[DeviceList.NTamd64]
; DisplayName            Section           DeviceId
; -----------            -------           --------
%vnUsbCl8911Win10.DRVDESC%=vnUsbCl8911_Inst,   PCI\VEN_19E2&DEV_4010

;-------------------------------------------------------------------------
; Class Section
;-------------------------------------------------------------------------
[ClassInstall32]
Addreg         = CANClassReg

[CANClassReg]
HKR,,,0,%ClassName%
HKR,,Icon,,-5

;-------------------------------------------------------------------------
; Device Install Section
;-------------------------------------------------------------------------
[ControlFlags]
ExcludeFromSelect = *

[Manufacturer]
%MSFT%=DeviceList,NTamd64

;------------------------------------------------------------------------------
;  Installation Disk Information
;------------------------------------------------------------------------------
[SourceDisksFiles]
vnUsbClient8911Win10.sys = 1
WdfCoInstaller01009.dll = 1 ; make sure the number matches with SourceDisksNames

[SourceDisksNames]
1=%DISK_NAME%,

;------------------------------------------------------------------------------
; DestinationDirs 
;------------------------------------------------------------------------------
[DestinationDirs]
DefaultDestDir=12
CoInstaller_CopyFiles = 11

;------------------------------------------------------------------------------
;  Windows 2000 / XP Sections for USBClient VN8911
;------------------------------------------------------------------------------
[vnUsbCl8911_Inst.NTamd64]
CopyFiles      = @vnUsbClient8911Win10.sys

[vnUsbCl8911_Inst.NTamd64.Services]
AddService     = vnUsbCl8911,0x00000002,vnUsbCl8911_Service

[vnUsbCl8911_Inst.NTamd64.HW]
AddReg=vnUsbCl8911.hw.registry

[vnUsbCl8911_Service]
DisplayName    = %vnUsbCl8911Win10.SVCDESC%
ServiceType    = 1                  ; SERVICE_KERNEL_DRIVER
StartType      = 3                  ; SERVICE_DEMAND_START
ErrorControl   = 1                  ; SERVICE_ERROR_NORMAL
ServiceBinary  = %12%\vnUsbClient8911Win10.sys

;-------------------------------------------------------------------------
; WDF Coinstaller installation
;-------------------------------------------------------------------------
[vnUsbCl8911_Inst.NTamd64.CoInstallers]
AddReg         = CoInstaller_AddReg
CopyFiles      = CoInstaller_CopyFiles

[CoInstaller_CopyFiles]
WdfCoInstaller01009.dll

[CoInstaller_AddReg]
HKR,,CoInstallers32,0x00010000, "WdfCoInstaller01009.dll,WdfCoInstaller"

[vnUsbCl8911_Inst.NTamd64.Wdf]
KmdfService    = vnUsbCl8911, vnUsbCl8911_wdfsect

[vnUsbCl8911_wdfsect]
KmdfLibraryVersion = 1.9

[vnUsbCl8911.hw.registry] ; MSI support
HKR, Interrupt Management,, 0x00000010
HKR, Interrupt Management\MessageSignaledInterruptProperties,, 0x00000010
HKR, Interrupt Management\MessageSignaledInterruptProperties, MSISupported, 0x00010001, 1
HKR, Interrupt Management\MessageSignaledInterruptProperties, MessageNumberLimit, 0x00010001, 1

;------------------------------------------------------------------------------
;  String Definitions
;------------------------------------------------------------------------------
[Strings]
MSFT           = "Vector Informatik GmbH"
ClassName      = "Vector-Hardware"
vnUsbCl8911Win10.SVCDESC   = "USBClient8911Win10"
vnUsbCl8911Win10.DRVDESC   = "USBClient8911Win10"
DISK_NAME      = "vnUsbClient-Driver"

