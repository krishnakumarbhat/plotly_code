# Singularity/Apptainer definition file for CAN KPI tool
# Build from workspace root with:
#   apptainer build --fakeroot can_kpi/can_kpi.simg can_kpi/can_singularity_KPI.def

Bootstrap: docker
From: docker.io/python:3.10-slim

%labels
    Name CAN_KPI
    Version 1.0
    Author ouymc2
    Description CAN KPI HTML generation (JSON batch and HDF pair modes)

%environment
    umask 022
    export PYTHONUNBUFFERED=1
    export PATH=/opt/venv/bin:$PATH
    export PYTHONPATH=/app/can_kpi:$PYTHONPATH

%post
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    python -m venv /opt/venv
    . /opt/venv/bin/activate
    pip install --upgrade pip setuptools wheel
    pip install --no-cache-dir numpy pandas h5py plotly

    mkdir -p /app/can_kpi /app/output
    chmod -R 755 /app

%files
    can_kpi/a_persistence_layer /app/can_kpi/a_persistence_layer
    can_kpi/b_data_storage /app/can_kpi/b_data_storage
    can_kpi/c_business_layer /app/can_kpi/c_business_layer
    can_kpi/d_presentation_layer /app/can_kpi/d_presentation_layer
    can_kpi/kpi_main.py /app/can_kpi/kpi_main.py
    can_kpi/kpi.json /app/can_kpi/kpi.json

%runscript
    . /opt/venv/bin/activate
    umask 022

    MODE="${1:-help}"
    shift 2>/dev/null || true

    case "$MODE" in
        json)
            if [ -z "${1:-}" ]; then
                echo "Usage: singularity run can_kpi.simg json <kpi_json> [html_dir]"
                exit 1
            fi
            JSON_FILE="$1"
            HTML_DIR="${2:-/app/output/html}"
            mkdir -p "$HTML_DIR"
            cd /app/can_kpi
            exec python kpi_main.py "$JSON_FILE" "$HTML_DIR"
            ;;

        hdf)
            if [ -z "${1:-}" ] || [ -z "${2:-}" ]; then
                echo "Usage: singularity run can_kpi.simg hdf <input.h5> <output.h5> [html_dir]"
                exit 1
            fi
            INPUT_HDF="$1"
            OUTPUT_HDF="$2"
            HTML_DIR="${3:-/app/output/html}"
            TMP_JSON="/tmp/can_kpi_pair.json"
            cat > "$TMP_JSON" <<EOF
{
  "INPUT_HDF": ["$INPUT_HDF"],
  "OUTPUT_HDF": ["$OUTPUT_HDF"]
}
EOF
            mkdir -p "$HTML_DIR"
            cd /app/can_kpi
            exec python kpi_main.py "$TMP_JSON" "$HTML_DIR"
            ;;

        help|--help|-h|*)
            echo "CAN KPI Container"
            echo "Usage: singularity run can_kpi.simg <mode> [args]"
            echo "Modes:"
            echo "  json <kpi_json> [html_dir]"
            echo "  hdf <input.h5> <output.h5> [html_dir]"
            exit 0
            ;;
    esac

%test
    . /opt/venv/bin/activate
    python -c "import numpy, pandas, h5py, plotly; print('CAN KPI deps OK')"
