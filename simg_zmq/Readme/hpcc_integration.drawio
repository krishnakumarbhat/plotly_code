    <diagram id="runtime-flow" name="Runtime Flow">
        <mxGraphModel dx="2486" dy="1856" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="1. Operator runs simg_sh_hpcc/main_hpcc.sh on the HPCC login node" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="60" y="60" width="260" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="2. main_hpcc.sh starts hpcc_main.pyz --broker-only and main_html.simg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="400" y="60" width="300" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="3. Public services bind 5001 for main_html and 9100 for the broker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="780" y="60" width="310" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="4. User opens /html and authenticates into the shared HPCC session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="1180" y="60" width="300" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="5. KPI form submits a runtime payload to the broker over the socket API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="805" y="160" width="260" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="7" value="6. Broker stores runtime_jobs metadata and writes slurm_tmux_launcher.sh" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="400" y="240" width="300" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="8" value="7. Slurm allocation stays PENDING until a tmux pane writes a START marker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="780" y="310" width="310" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="9" value="8. Compute starts inside the Slurm allocation; UDP + Interactive Plot share one tmux-backed session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="1210" y="310" width="300" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="10" value="9. Dashboard/history/job log show PENDING before RUNNING, then sync final result" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="1020" y="700" width="300" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="11" value="10. Chat requests go to rag.simg over HTTP /ask" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="160" y="550" width="300" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="12" value="11. Hyperlink stores roots in session and serves /hyperlink/ viewer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="660" y="550" width="320" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="13" value="12. Runtime Map edits runtime_tools and can launch nodes directly" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="1490" y="450" width="320" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="14" value="start" style="edgeStyle=orthogonalEdgeStyle;html=1;" parent="1" source="2" target="3" edge="1">
