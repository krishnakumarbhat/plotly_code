Bootstrap: docker
From: docker.io/python:3.10-slim

%labels
    Name RAG_Service
    Version 1.0
    Author ouymc2
    Description Retrieval augmented generation service for the HPCC runtime console

%environment
    export PYTHONUNBUFFERED=1
    export PATH=/opt/venv/bin:$PATH
    export PYTHONPATH=/app/rag
    export FLASK_HOST=${FLASK_HOST:-0.0.0.0}
    export FLASK_PORT=${FLASK_PORT:-5100}
    export VECTOR_BACKEND=${VECTOR_BACKEND:-chroma}
    export LLAMA_SERVER_PATH=${LLAMA_SERVER_PATH:-/app/rag/tools/llama.cpp/llama-server}

%post
    apt-get update && apt-get install -y --no-install-recommends ca-certificates wget \
        && rm -rf /var/lib/apt/lists/*

    python -m venv /opt/venv
    . /opt/venv/bin/activate
    pip install --upgrade pip setuptools wheel
    # Install CPU-only PyTorch FIRST — prevents pulling 2.7 GB of nvidia-* CUDA
    # packages that sentence-transformers would otherwise bring in.
    pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu
    pip install --no-cache-dir -r /app/rag/requirements.txt
    pip install --no-cache-dir opencv-python-headless Pillow

    # Download pre-built llama-server (b9860) instead of compiling from source
    mkdir -p /app/rag/tools/llama.cpp
    LLAMA_RELEASE=b9860
    wget -q "https://github.com/ggml-org/llama.cpp/releases/download/${LLAMA_RELEASE}/llama-${LLAMA_RELEASE}-bin-ubuntu-x64.tar.gz" \
        -O /tmp/llama.tar.gz
    mkdir -p /tmp/llama-extract
    tar -xzf /tmp/llama.tar.gz -C /tmp/llama-extract
    LS=$(find /tmp/llama-extract -name 'llama-server' -type f | head -1)
    if [ -z "$LS" ]; then
        echo "ERROR: llama-server binary not found in pre-built archive" >&2
        ls -R /tmp/llama-extract 2>/dev/null | head -20
        exit 1
    fi
    cp "$LS" /app/rag/tools/llama.cpp/llama-server
    chmod 755 /app/rag/tools/llama.cpp/llama-server
    # Copy ALL shared libraries + symlinks needed by llama-server (newer
    # releases use a thin wrapper + libllama-server-impl.so + ggml CPU libs).
    cp -a /tmp/llama-extract/llama-b9860/*.so* /app/rag/tools/llama.cpp/
    chmod 755 /app/rag/tools/llama.cpp/*.so*
    rm -rf /tmp/llama.tar.gz /tmp/llama-extract

    chmod -R 755 /app

    # cleanup
    apt-get remove -y wget
    apt-get autoremove -y && apt-get clean
    rm -rf /var/lib/apt/lists/*

%files
    rag/app /app/rag/app
    rag/main.py /app/rag/main.py
    rag/run.py /app/rag/run.py
    rag/vlm_process.py /app/rag/vlm_process.py
    rag/requirements.txt /app/rag/requirements.txt

%runscript
    . /opt/venv/bin/activate
    cd /app/rag
    exec python main.py "$@"

%test
    . /opt/venv/bin/activate
    python -c "import flask; print(flask.__version__)"

%help
    RAG service image for the HPCC Runtime Console.

    Usage:
      singularity run rag.simg --talk
            singularity run rag.simg --scrap /path/to/html/root

    Default service port:
      FLASK_PORT=5100