# Runtime env defaults — override via .env
HPCC_RUNTIME_LOCAL_ROOT="/local/hpc_tools"
HPCC_RUNTIME_WORK_ROOT="/local/hpcc_runtime"
HPCC_SLURM_IMMEDIATE_SECONDS=""
HPCC_PORT_CONFLICT_POLICY="kill"

HPCC_REQUIRE_SLURM_FOR_KPI="1"
HPCC_ALLOW_LOCAL_KPI="0"
HPCC_AUTO_START_RAG="1"

PORT="5003"
RAG_PORT="5004"

WORKERS="4"
THREADS="4"
KEEPALIVE="5"
TIMEOUT="240"