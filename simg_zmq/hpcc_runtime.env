# AGENT INSTRUCTION: Keep HPCC runtime defaults centralized here and prefer explicit overrides over inline launcher edits.

HPCC_KRAKOW_DEPLOY_ROOT="/net/8k3/e0fs01/irods/PLKRA-PROJECTS/RNA-SDV-SRR7/4-Checkout/all_services_3"
HPCC_SOUTHFIELD_DEPLOY_ROOT="/mnt/usmidet/projects/RADARCORE/2-Sim/all_services_3"

HPCC_RUNTIME_LOCAL_ROOT="/local/hpc_tools"
HPCC_RUNTIME_WORK_ROOT="/local/hpcc_runtime"
HPCC_SLURM_IMMEDIATE_SECONDS=""
HPCC_PORT_CONFLICT_POLICY="kill"

HPCC_REQUIRE_SLURM_FOR_KPI="1"
HPCC_ALLOW_LOCAL_KPI="0"
HPCC_AUTO_START_RAG="1"

PORT="5003"
RAG_PORT="5004"

WORKERS="4"
THREADS="4"
KEEPALIVE="5"
TIMEOUT="240"

# VLM (Vision Language Model) — Gemma-4 via llama.cpp inside rag.simg on Slurm compute node
# Requires rag.simg built with vlm_process.py and opencv-python-headless
VLM_RAG_SIMG_PATH=""              # e.g., /net/.../4-Checkout/all_services_3/rag/rag.simg
GEMMA_GGUF_PATH=""                # e.g., /net/.../models/gemma-4-vl.gguf (bind-mounted into container)
VLM_PARTITION=""                  # Slurm partition for VLM jobs (defaults to VLM_PARTITION or compute)
VLM_ACCOUNT=""                    # Slurm account for VLM jobs (optional)
VLM_MEMORY="64G"                  # Memory per VLM job
VLM_POLL_TIMEOUT="300"            # Max seconds to wait for VLM job completion