digraph WorkProjectFlow {
  rankdir=LR;
  graph [label="Work Project Runtime Flow", labelloc=t, fontsize=20];
  node [shape=box, style=rounded];

  subgraph cluster_ui {
    label="Flask Web Layer";
    color=lightgrey;
    browser [label="Browser UI\n/templates/index.html"];
    flask [label="flask_app.py\n/api/chat"];
    browser -> flask [label="POST message"];
  }

  subgraph cluster_core {
    label="Core Service";
    color=lightblue;
    service [label="WorkChatService\nchat_service.py"];
    telemetry [label="TelemetryManager\nLangSmith + Langfuse"];
    kb [label="ChromaKnowledgeBase\nknowledge_base.py"];
    llm [label="LocalLlamaRuntime\nmodel_runtime.py"];

    service -> telemetry [label="setup tracing"];
    service -> kb [label="ingest/retrieve"];
    service -> llm [label="build LlamaCpp"];
  }

  subgraph cluster_graph {
    label="LangGraph Agent Flow";
    color=lightyellow;
    plan [label="plan node\nRETRIEVE or DIRECT"];
    retrieve [label="retrieve node\nquery Chroma"];
    direct [label="direct node\nno retrieval"];
    answer [label="answer node\nllm.invoke()"];

    plan -> retrieve [label="needs retrieval"];
    plan -> direct [label="direct"];
    retrieve -> answer;
    direct -> answer;
  }

  flask -> service [label="chat_service.ask()"];
  service -> plan [label="graph.invoke(state)"];
  answer -> flask [label="answer JSON"];
  flask -> browser [label="render response"];
}
